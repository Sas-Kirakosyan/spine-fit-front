          { "label": "38%+ (High body fat)", "description": "Higher fat storage around waist and hips" }
        ]
      },
      "10": {
        "question": "How long have you been training with weights?",
        "options": [
          "Beginner — new to training",
          "Intermediate — 1 to 3 years",
          "Advanced — 3+ years"
        ]
      },
      "11": {
