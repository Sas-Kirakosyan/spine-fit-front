      },
      "2": {
        "question": "What is your main training goal?",
        "options": [
          "Muscle Hypertrophy (Build mass safely with back/sciatica history)",
          "Structural Recovery (Reduce pain and restore movement capacity)"
        ]
      },
      "3": {
        "question": "How would you describe your current back health?",
        "options": [
          "Healthy (I am pain-free, but cautious)",
          "Recovered (Past history of pain/injury)",
          "Active Symptoms (Currently experiencing discomfort)"
        ],
        "disabledNoteHypertrophy": "\"Active Symptoms\" is unavailable: muscle hypertrophy training is not recommended while you are currently experiencing pain.",
        "disabledNoteRecovery": "\"Healthy\" and \"Recovered\" are unavailable: structural recovery is designed for users who currently have pain to reduce."
      },
      "4": {
        "question": "Where is — or was — your pain located?",
        "options": [
          "Lower Back (L4-L5/S1 area)",
          "Sciatica (Pain radiating down leg)",
          "Glute / Deep Hip discomfort",
          "Calf or Foot (Numbness/Tingling)"
        ],
        "calfFootWarning": "Numbness or tingling in the calf or foot may indicate nerve compression. Please consult a doctor before starting any training program."
      },
      "5": {
        "question": "Rate your current pain level (0 = none, 10 = severe)"
      },
      "6": {
        "question": "Which movements trigger your pain or discomfort?",
        "options": [
          "Bending forward (e.g., reaching for the floor)",
          "Arching backward (e.g., reaching overhead)",
          "Lifting or carrying heavy objects",
          "Sitting for longer than 20–30 minutes",
          "Impact movements (Running, Jumping)",
          "Rotating or twisting the torso",
          "Straining (Heavy bracing/holding breath)"
        ]
      },
      "7": {
        "question": "How comfortable are you squatting with added weight?",
        "options": [
          "Confident (I squat with weights regularly)",
          "Cautious (I only squat with light weights)",
          "Technical (I can squat bodyweight, but weights trigger pain)",
          "Avoidant (I strictly avoid all squatting movements)",
          "Untested (I haven't tried squatting recently)"
        ]
      },
      "8": {
        "question": "Your Body Stats",
        "description": "Helps us calibrate your training volume and intensity.",
        "fields": {
          "gender": {
            "label": "Gender",
            "options": ["Male", "Female", "Other"]
          },
          "dateOfBirth": {
            "label": "Date of Birth"
          },
