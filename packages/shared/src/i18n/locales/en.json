            "label": "Height",
            "placeholder": "Enter height"
          },
          "weight": {
            "label": "Weight",
            "placeholder": "Enter weight"
          }
        }
      },
      "9": {
        "question": "Which physique best matches yours?",
        "options": [
          { "label": "8–15% (Lean / Athletic)", "description": "Visible muscle definition" },
          { "label": "16–22% (Average)", "description": "Some definition, slight fat around waist" },
          { "label": "23–30% (Overfat)", "description": "Soft midsection, limited muscle definition" },
          { "label": "30%+ (High body fat)", "description": "Higher fat storage around waist and hips" }
        ],
        "optionsFemale": [
          { "label": "18–24% (Lean / Athletic)", "description": "Visible muscle definition, athletic build" },
          { "label": "25–31% (Fit/Average)", "description": "Healthy, balanced physique" },
