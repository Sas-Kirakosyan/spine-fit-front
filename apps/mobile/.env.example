# Backend API (plan generation). On a real device "localhost" points to the
# phone itself — use your computer's LAN IP instead, e.g. http://192.168.1.10:4000.
# On the Android emulator use http://10.0.2.2:4000.
EXPO_PUBLIC_API_URL=http://localhost:4000

# Supabase project (same values as apps/web/.env, without the VITE_ prefix)
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
